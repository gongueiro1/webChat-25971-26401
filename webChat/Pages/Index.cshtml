@page
@model IndexModel
@{
    ViewData["Title"] = "Home Page";
}

<div class="container mt-4">
    <div class="row">
        
        <div class="col-md-8">
            
            @if (Model.Posts == null || !Model.Posts.Any())
            {
                <div class="card shadow-sm border-0 rounded-3 text-center py-5">
                    <div class="card-body text-muted">
                        <h5 class="fw-bold">Nenhum post encontrado.</h5>
                        <p>Sê o primeiro a quebrar o gelo e a partilhar algo!</p>
                    </div>
                </div>
            }
            else
            {
                @foreach (var post in Model.Posts)
                {
                    <div class="card mb-3 shadow-sm border-0 rounded-3">
                        <div class="card-body">
                            
                            <div class="text-muted small mb-2 d-flex align-items-center justify-content-between">
                                <div class="d-flex align-items-center">
                                    <img src="@(string.IsNullOrEmpty(post.ProfileImage) ? "/images/default-avatar.png" : post.ProfileImage)" 
                                         alt="Avatar" class="rounded-circle me-2" style="width: 24px; height: 24px; object-fit: cover;" />
                                    
                                    <span>
                                        Postado por <span class="fw-bold text-dark">u/@(string.IsNullOrEmpty(post.AuthorName) ? "Anonimo" : post.AuthorName)</span> 
                                        • há @(Math.Round((DateTime.UtcNow - post.CreatedAt).TotalHours)) horas
                                    </span>
                                </div>

                                <div>
                                    <a asp-page="/Posts/Delete" asp-route-id="@post.Id" class="btn btn-danger btn-sm fw-bold">
                                        <i class="bi bi-trash3"></i> Apagar
                                    </a>
                                </div>
                            </div>
                            
                            <h5 class="card-title fw-bold text-dark mb-1">@post.Title</h5>
                            <p class="card-text text-secondary mb-3">@post.Content</p>
                            
                            <div class="d-flex justify-content-between align-items-center border-top pt-3 mt-2">
                                <div>
                                    <button class="btn btn-sm btn-outline-secondary px-3"><i class="bi bi-caret-up-fill"></i> Upvote</button>
                                    <button class="btn btn-sm btn-outline-secondary px-3"><i class="bi bi-caret-down-fill"></i> Downvote</button>
                                </div>
                                <div class="text-muted small">
                                    <i class="bi bi-chat-left-text"></i> Comentários
                                </div>
                            </div>
                            
                        </div>
                    </div>
                }
            }
            
        </div>

        <div class="col-md-4">
            <div class="card shadow-sm border-0 rounded-3 bg-light sticky-top" style="top: 20px;">
                <div class="card-body">
                    <h6 class="card-title fw-bold">Sobre o webChat</h6>
                    <p class="card-text text-muted small">A tua nova comunidade para partilhar ideias e falar de tópicos interessantes.</p>
                    <a asp-page="/Posts/Create" class="btn btn-primary w-100 fw-bold">Criar Novo Post</a>
                </div>
            </div>
        </div>
        
    </div>
</div>