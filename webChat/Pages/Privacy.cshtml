@page
@model PrivacyModel
@{
    ViewData["Title"] = "Privacy Policy";
}

<div class="privacy-container">
    <div class="privacy-card">
        <h1>Privacy Policy</h1>
        <p class="intro">
            At <strong>Talkr.</strong>, we respect your privacy and keep your data safe.
        </p>

        <section>
            <h2>What we collect?</h2>
            <p>
                We may store basic account information such as your username, email address,
                profile image and posts created on the platform.
            </p>
        </section>

        <section>
            <h2>How we use your data?</h2>
            <p>
                Your data is only used to let you log in, create posts, interact with content
                and improve your experience on Talkr.
            </p>
        </section>

        <section>
            <h2>Your control</h2>
            <p>
                You can manage your account information through your profile page.
            </p>
        </section>

        <p class="footer-note">
            Last updated: 2026
        </p>
    </div>
</div>