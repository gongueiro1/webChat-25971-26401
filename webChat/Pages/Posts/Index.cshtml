@page
@model webChat.Pages.Posts.IndexModel
@{
    ViewData["Title"] = "Feed";
}

<!-- ALERTA DE NOVO POST (Estilo Twitter/X - Flutuante no topo centro) -->
<div id="newPostAlert" class="position-fixed d-none" style="top: 80px; left: 50%; transform: translateX(-50%); z-index: 1050; cursor: pointer; transition: all 0.3s ease;" onclick="window.location.reload();">
    <div class="px-4 py-2 rounded-pill shadow text-white fw-bold d-flex align-items-center justify-content-center gap-2" style="background-color: #a4ce3a; font-size: 0.95rem;">
        ↑ <span id="newPostText">Show 1 post</span>
    </div>
</div>

<div class="container mt-4">
    <div class="row">
        <div class="col-lg-8">
            
            @if (Model.Posts == null || !Model.Posts.Any())
            {
                <div class="card shadow-sm border-0 rounded-4 text-center py-5">
                    <div class="card-body text-muted">
                        <h5 class="fw-bold">No posts found.</h5>
                        <p>Be the first to share something.</p>
                    </div>
                </div>
            }
            else
            {
                @foreach (var post in Model.Posts)
                {
                    <div class="card mb-3 shadow-sm border-0 rounded-4 post-card-hover">
                        <a asp-page="./Details"
                           asp-route-id="@post.Id"
                           class="text-decoration-none text-dark">
                            
                            <div class="card-body">
                                <div class="d-flex align-items-center mb-3">
                                    <img src="@post.ProfileImage" 
                                         class="post-avatar me-2 rounded-circle" 
                                         style="width: 36px; height: 36px; object-fit: cover; flex-shrink: 0;" />

                                    <div>
                                        <div class="small text-muted">
                                            Posted by
                                            <span class="fw-bold text-dark">
                                                @post.AuthorName
                                            </span>
                                            • @post.TimeAgo
                                        </div>
                                    </div>
                                </div>

                                <h3 class="fw-bold">@post.Title</h3>
                                <p class="mb-0 mt-3">@post.Content</p>
                            </div>
                        </a>

                        <div class="px-3 pb-3">
                            <hr />
                            <div class="d-flex gap-2 flex-wrap">
                                
                                <form method="post" asp-page-handler="Support" asp-route-id="@post.Id">
                                    <button type="submit" 
                                            class="btn btn-sm px-4 rounded-pill fw-bold transition-all @(post.IsSupportedByCurrentUser ? "btn-primary" : "btn-outline-primary")">
                                        Support · @post.FormattedSupportCount
                                    </button>
                                </form>

                                <a asp-page="./Details"
                                   asp-route-id="@post.Id"
                                   class="btn btn-sm btn-outline-secondary px-4 rounded-pill">
                                    Discuss · @post.CommentCount
                                </a>

                                @if (User.Identity?.IsAuthenticated == true &&
                                     post.UserId == User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value)
                                {
                                    <form method="post" asp-page-handler="DeletePost" asp-route-id="@post.Id">
                                        <button type="submit"
                                                class="btn btn-sm btn-outline-danger rounded-pill"
                                                onclick="return confirm('Are you sure you want to delete this post?');">
                                            Delete
                                        </button>
                                    </form>
                                }
                            </div>
                        </div>
                    </div>
                }
            }
        </div>

        <div class="col-lg-4">
            
            <a asp-area="" asp-page="/Privacy" 
               class="card border-0 shadow-sm rounded-4 mb-3 text-decoration-none text-dark card-hover d-block" 
               style="transition: transform 0.2s ease, box-shadow 0.2s ease;">
                <div class="card-body">
                    <h3 class="fw-bold fs-4">About Talkr.</h3>
                    <p class="text-secondary mb-0">
                        The forum where you can share your thoughts on your favorite topics!
                    </p>
                </div>
            </a>

            <a asp-page="./Create"
               class="btn text-white w-100 py-2 rounded-pill fw-bold" style="background-color: #a4ce3a; border-color: #a4ce3a;">
                Create new post
            </a>

        </div>
    </div>
</div>

@section Scripts {
    <!-- BILIOTECA SIGNALR -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.7/signalr.min.js"></script>

    <script>
        document.addEventListener("DOMContentLoaded", function () {
            
            const connection = new signalR.HubConnectionBuilder()
                .withUrl("/chatHub")
                .build();

            connection.start().catch(err => console.error(err.toString()));

            let novosPosts = 0; 

            connection.on("ReceiveNewPost", function (data) {
                const currentUser = '@(User.Identity?.Name ?? "")';
                
                if (data.author !== currentUser) {
                    novosPosts++;
                    
                    const alertBox = document.getElementById("newPostAlert");
                    const alertText = document.getElementById("newPostText");
                    
                    if (novosPosts === 1) {
                        alertText.textContent = `Show 1 post`;
                    } else {
                        alertText.textContent = `Show ${novosPosts} posts`;
                    }
                    
                    alertBox.classList.remove("d-none"); 

                    // Efeito visual adaptado para manter a pílula centrada (-50% X) durante o salto
                    alertBox.style.transform = "translateX(-50%) scale(1.05)";
                    setTimeout(() => alertBox.style.transform = "translateX(-50%) scale(1)", 200);
                }
            });
        });
    </script>
}