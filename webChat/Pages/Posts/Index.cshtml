@page
@model webChat.Pages.Posts.IndexModel
@{
    ViewData["Title"] = "Feed";
}

<div class="container mt-4">

    <div class="row">

        <div class="col-lg-8">

            @if (Model.Posts == null || !Model.Posts.Any())
            {
                <div class="card shadow-sm border-0 rounded-4 text-center py-5">
                    <div class="card-body text-muted">
                        <h5 class="fw-bold">No posts found.</h5>
                        <p>Be the first to share something.</p>
                    </div>
                </div>
            }
            else
            {
                @foreach (var post in Model.Posts)
                {
                    <div class="card mb-3 shadow-sm border-0 rounded-4 post-card-hover">

                        <a asp-page="./Details"
                           asp-route-id="@post.Id"
                           class="text-decoration-none text-dark">

                            <div class="card-body">

                                <div class="d-flex align-items-center mb-3">

                                    <img src="@post.ProfileImage"
                                         class="post-avatar me-2" />

                                    <div>
                                        <div class="small text-muted">
                                            Posted by
                                            <span class="fw-bold text-dark">
                                                @post.AuthorName
                                            </span>
                                            • há @((DateTime.UtcNow - post.CreatedAt).Hours) horas
                                        </div>
                                    </div>

                                </div>

                                <h3 class="fw-bold">
                                    @post.Title
                                </h3>

                                <p class="mb-0 mt-3">
                                    @post.Content
                                </p>

                            </div>

                        </a>

                        <div class="px-3 pb-3">

                            <hr />

                            <div class="d-flex gap-2 flex-wrap">

                                <form method="post"
                                      asp-page-handler="Support"
                                      asp-route-id="@post.Id">

                                    <button type="submit"
                                            class="btn btn-sm btn-outline-primary px-4 rounded-pill">
                                        Support · @post.FormattedSupportCount
                                    </button>

                                </form>

                                <a asp-page="./Details"
                                   asp-route-id="@post.Id"
                                   class="btn btn-sm btn-outline-secondary px-4 rounded-pill">
                                    Discuss
                                </a>

                                @if (post.UserId == User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value)
                                {
                                    <form method="post"
                                          asp-page-handler="DeletePost"
                                          asp-route-id="@post.Id">

                                        <button type="submit"
                                                class="btn btn-sm btn-outline-danger rounded-pill">
                                            Delete
                                        </button>

                                    </form>
                                }

                            </div>

                        </div>

                    </div>
                }
            }

        </div>

        <div class="col-lg-4">

            <div class="card border-0 shadow-sm rounded-4 mb-3">

                <div class="card-body">

                    <h3 class="fw-bold fs-4">
                        Sobre o Talkr.
                    </h3>

                    <p class="text-secondary mb-0">
                        The forum where you can share your thoughts on your favorite topics!
                    </p>

                </div>

            </div>

            <a asp-page="./Create"
               class="btn btn-primary w-100 py-2 rounded-pill">
                Create new post
            </a>

        </div>

    </div>

</div>