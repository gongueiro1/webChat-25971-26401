@page
@model webChat.Pages.Posts.CreateModel

@{
    ViewData["Title"] = "Create Post";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm border-0 rounded-3">
                
                <div class="card-header bg-primary text-white py-3">
                    <h4 class="mb-0">
                        <i class="bi bi-pencil-square me-2"></i>New Post
                    </h4>
                </div>

                <div class="card-body p-4">

                    <form method="post" id="postForm">

                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="mb-4">
                            <label asp-for="Post.Title" class="form-label fw-bold text-muted">
                                Title
                            </label>

                            <input asp-for="Post.Title"
                                   class="form-control form-control-lg"
                                   placeholder="Title" />

                            <span asp-validation-for="Post.Title"
                                  class="text-danger small"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Post.Content"
                                   class="form-label fw-bold text-muted">
                                Text
                            </label>

                            <textarea asp-for="Post.Content"
                                      id="contentBox"
                                      class="form-control"
                                      rows="6"
                                      placeholder="Share what you think!"
                                      style="resize: none;"></textarea>

                            <span asp-validation-for="Post.Content"
                                  class="text-danger small"></span>
                        </div>

                        <div class="d-flex justify-content-between align-items-center mt-4">

                            <a asp-page="./Index"
                               class="btn btn-outline-secondary px-4">
                                Cancel
                            </a>

                            <button type="submit"
                                    class="btn btn-primary px-5 fw-bold">
                                Publish
                            </button>

                        </div>

                    </form>

                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {

    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        document.getElementById("contentBox")
            .addEventListener("keydown", function (e) {

                if (e.ctrlKey && e.key === "Enter") {
                    e.preventDefault();
                    document.getElementById("postForm").submit();
                }

            });
    </script>
}